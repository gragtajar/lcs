{
  "name": "learncivicsense-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "learncivicsense.in — fast, multilingual civic-sense website (Astro + Pagefind)",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .ts,.tsx,.astro,.js,.mjs,.cjs --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.astro,.js,.mjs,.cjs --fix",
    "stylelint": "stylelint \"src/styles/**/*.css\"",
    "typecheck": "astro sync && tsc --noEmit",
    "lhci": "lhci autorun --config=lighthouserc.json",
    "lhci:mobile": "lhci autorun --config=lighthouserc.mobile.json",
    "size": "size-limit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,astro,js,mjs,cjs}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/preact": "^4.0.1",
    "@sentry/astro": "^8.45.0",
    "astro": "^5.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.0",
    "pagefind": "^1.2.0",
    "preact": "^10.25.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@lhci/cli": "^0.14.0",
    "@size-limit/file": "^11.1.6",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "astro-eslint-parser": "^1.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "size-limit": "^11.1.6",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1",
    "typescript": "^5.7.0"
  }
}
