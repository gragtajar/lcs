---
import '../styles/tokens.css';
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Footer from '../components/Footer.astro';
import AnalyticsLoader from '../components/AnalyticsLoader.astro';
import { t } from '../lib/i18n';
import { buildMeta } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  /** Container width class. 'narrow' = article, 'wide' = full content, 'flush' = none (page handles its own). */
  width?: 'narrow' | 'wide' | 'flush';
  /** Optional override for canonical path; defaults to the request URL. */
  canonical?: string;
  /** Page semantic type; influences og:type + JSON-LD. */
  type?: 'website' | 'article';
  /** Absolute URL of the OG/Twitter card image (when set, uses summary_large_image). */
  image?: string;
  /** Optional OG/Twitter title override (defaults to the suffixed page title). */
  ogTitle?: string;
  /** Optional OG/Twitter description override (defaults to `description`). */
  ogDescription?: string;
}

const {
  title,
  description = t('siteTagline'),
  width = 'wide',
  canonical,
  type = 'website',
  image,
  ogTitle,
  ogDescription,
} = Astro.props;

const meta = buildMeta({
  title: title ?? '',
  description,
  path: canonical ?? Astro.url.pathname,
  type,
  image,
  ogTitle,
  ogDescription,
});

// Analytics: only inject the Cloudflare Web Analytics beacon when a token is
// present in the build env. Local dev and forked PRs run without it.
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN as string | undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#FAF8F3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#15181A" media="(prefers-color-scheme: dark)" />
    <title>{meta.fullTitle}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={meta.canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:type" content={meta.ogType} />
    <meta property="og:title" content={meta.ogTitle} />
    <meta property="og:description" content={meta.ogDescription} />
    <meta property="og:url" content={meta.canonicalUrl} />
    <meta property="og:site_name" content="learncivicsense.in" />
    <meta property="og:locale" content="en_IN" />
    {meta.ogImage && <meta property="og:image" content={meta.ogImage} />}

    {/* Twitter */}
    <meta name="twitter:card" content={meta.twitterCard} />
    <meta name="twitter:title" content={meta.ogTitle} />
    <meta name="twitter:description" content={meta.ogDescription} />
    {meta.ogImage && <meta name="twitter:image" content={meta.ogImage} />}

    {
      /*
      Icons + PWA manifest. PNG variants (favicon-32, apple-touch-icon) are added
      when real brand artwork lands; for now the SVG favicon scales fine on modern
      browsers, and the manifest gives Android home-screen colour cues.
    */
    }
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />

    {
      /*
      Theme init: pre-paint script that picks the saved or system theme and writes it
      to <html data-theme>. Inlined so it runs before first paint (no flash of wrong theme).
    */
    }
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('lcs-theme');
          const sys = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          const theme = saved === 'light' || saved === 'dark' ? saved : sys;
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>

    {
      /*
      Self-hosting Hind would require shipping the woff2 files. Until those are
      placed in /public/fonts/, the system fallback stack defined in tokens.css
      keeps the site readable. To enable Hind, drop the subsetted woff2 files in
      /public/fonts/ and uncomment the @font-face + preload below.
    */
    }
    <style is:inline>
      /*
      @font-face {
        font-family: 'Hind';
        src: url('/fonts/hind-regular.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Hind';
        src: url('/fonts/hind-medium.woff2') format('woff2');
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Hind';
        src: url('/fonts/hind-semibold.woff2') format('woff2');
        font-weight: 600;
        font-style: normal;
        font-display: swap;
      }
      */
    </style>
    <slot name="head" />

    {
      cfAnalyticsToken && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: cfAnalyticsToken })}
        />
      )
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <TopBar />
    <main id="main" class:list={['main', `width-${width}`]}>
      <slot />
    </main>
    <Footer />
    <AnalyticsLoader />

    <style>
      .main {
        min-height: 70vh;
      }
      .main.width-wide {
        max-width: var(--width-content);
        margin-inline: auto;
        padding: var(--space-5) var(--space-4) var(--space-7);
      }
      .main.width-narrow {
        max-width: var(--width-article);
        margin-inline: auto;
        padding: var(--space-5) var(--space-4) var(--space-7);
      }
      .main.width-flush {
        padding: 0;
      }
      @media (min-width: 768px) {
        .main.width-wide,
        .main.width-narrow {
          padding-inline: var(--space-6);
        }
      }
    </style>
  </body>
</html>
