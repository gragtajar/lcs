---
// /topics/ — the full catalog browser (India clusters, abroad packs, visitors module).
// Moved here from the old homepage when the homepage became the curated landing page
// (homepage redesign brief §2: "Browse all topics" links to a category-index page).
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import VisitorsCard from '../components/VisitorsCard.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getNavCategories, loadVisitorsModule } from '../lib/content';
import { t } from '../lib/i18n';

const nav = getNavCategories();
const indiaCats = nav.filter((c) => c.group === 'india');
const abroadCats = nav.filter((c) => c.group === 'abroad');
const visitors = loadVisitorsModule();
---

<BaseLayout title={t('home.categoriesHeading')} width="wide" canonical="/topics/">
  <Breadcrumb
    items={[{ label: t('nav.home'), href: '/' }, { label: t('home.categoriesHeading') }]}
  />

  <header class="topics-head">
    <h1 class="topics-title">{t('home.categoriesHeading')}</h1>
  </header>

  <!-- India -->
  <section class="home-section" aria-labelledby="india-h">
    <header class="home-section-head">
      <h2 id="india-h" class="home-section-title">{t('home.sectionIndia')}</h2>
      <p class="home-section-blurb">{t('home.sectionIndiaBlurb')}</p>
    </header>
    <div class="cat-grid">
      {indiaCats.map((c, i) => <CategoryCard category={c} openByDefault={i === 0} />)}
    </div>
  </section>

  <!-- Abroad -->
  <section class="home-section" aria-labelledby="abroad-h">
    <header class="home-section-head">
      <h2 id="abroad-h" class="home-section-title">{t('home.sectionAbroad')}</h2>
      <p class="home-section-blurb">{t('home.sectionAbroadBlurb')}</p>
    </header>
    <div class="cat-grid">
      {abroadCats.map((c) => <CategoryCard category={c} />)}
    </div>
  </section>

  <!-- Visitors -->
  <section class="home-section" aria-labelledby="visitors-h">
    <header class="home-section-head">
      <h2 id="visitors-h" class="home-section-title">{t('home.sectionVisitors')}</h2>
      <p class="home-section-blurb">{t('home.sectionVisitorsBlurb')}</p>
    </header>
    <div class="cat-grid cat-grid-single">
      <VisitorsCard visitors={visitors} />
    </div>
  </section>
</BaseLayout>

<script is:inline>
  /* Persist accordion open/close state across visits.
     Native <details> handles toggling — we only persist which IDs are open. */
  (function () {
    const KEY = 'lcs-topics-open';
    const nodes = document.querySelectorAll('details[data-cat-id]');

    let raw = null;
    try {
      raw = localStorage.getItem(KEY);
    } catch {
      /* localStorage unavailable */
    }
    if (raw !== null) {
      try {
        const saved = JSON.parse(raw);
        if (Array.isArray(saved)) {
          const openSet = new Set(saved);
          nodes.forEach(function (d) {
            d.open = openSet.has(d.getAttribute('data-cat-id'));
          });
        }
      } catch {
        /* malformed saved state; ignore */
      }
    }

    function persist() {
      const ids = [];
      nodes.forEach(function (d) {
        if (d.open) ids.push(d.getAttribute('data-cat-id'));
      });
      try {
        localStorage.setItem(KEY, JSON.stringify(ids));
      } catch {
        /* localStorage unavailable */
      }
    }
    nodes.forEach(function (d) {
      d.addEventListener('toggle', persist);
    });
  })();
</script>

<style>
  .topics-head {
    margin-bottom: var(--space-5);
  }
  .topics-title {
    font-size: var(--text-3xl);
  }
  .home-section {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }
  .home-section:first-of-type {
    border-top: 0;
    padding-top: 0;
    margin-top: 0;
  }
  .home-section-head {
    margin-bottom: var(--space-4);
  }
  .home-section-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
  }
  .home-section-blurb {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    max-width: 60ch;
  }
  .cat-grid {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .cat-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .cat-grid-single {
    grid-template-columns: 1fr;
    max-width: 720px;
  }
</style>
