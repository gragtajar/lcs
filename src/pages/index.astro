---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ClusterCard from '../components/ClusterCard.astro';
import MissionSection from '../components/MissionSection.astro';
import EngagementSlot from '../components/EngagementSlot.astro';
import { getFeaturedClusters, resolveHeroChips, getHomepageStats } from '../lib/homepage-data';
import { DEFAULT_LOCALE } from '../config.ts';
import { t } from '../lib/i18n';

// The rotation selects per build week (deterministic, stateless). BUILD_DATE lets a
// reproducible build or test pin the window; otherwise it's the current build time.
const buildDate = new Date(process.env.BUILD_DATE ?? Date.now());
const locale = DEFAULT_LOCALE;

const heroChips = resolveHeroChips(locale);
const { lessonCount, clusterCount } = getHomepageStats(locale);
const featured = getFeaturedClusters(locale, buildDate);
---

<BaseLayout title="" width="flush">
  <Hero chips={heroChips} lessonCount={lessonCount} clusterCount={clusterCount} />

  <section id="featured" class="home-featured" aria-labelledby="featured-h">
    <h2 id="featured-h" class="sr-only">Featured topics</h2>
    {
      featured.length > 0 ? (
        <>
          <div class="featured-stack">
            {featured.map((f) => (
              <ClusterCard featured={f} />
            ))}
          </div>
          <div class="featured-browse">
            <a href="/topics/">{t('homepage.clusterCards.browseAllTopics')}</a>
          </div>
        </>
      ) : (
        <p class="featured-empty">{t('list.comingSoon')}</p>
      )
    }
  </section>

  <section class="home-mission">
    <MissionSection />
  </section>

  <EngagementSlot />
</BaseLayout>

<style>
  .home-featured {
    padding: var(--space-6) var(--space-4) var(--space-4);
  }
  .featured-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .featured-browse {
    max-width: 960px;
    margin: var(--space-5) auto 0;
    text-align: center;
  }
  .featured-browse a {
    display: inline-block;
    min-height: 48px;
    padding: var(--space-3) var(--space-5);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-primary);
  }
  .featured-empty {
    text-align: center;
    color: var(--color-text-secondary);
    padding: var(--space-6) 0;
  }

  .home-mission {
    padding: var(--space-6) var(--space-4) var(--space-7);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-5);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  @media (min-width: 768px) {
    .home-featured,
    .home-mission {
      padding-inline: var(--space-6);
    }
  }
</style>
