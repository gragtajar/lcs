---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getNavCategories, getCategory } from '../../lib/content';
import { t } from '../../lib/i18n';

// Static path generation covers all 14 navigable categories (clusters + abroad packs).
export function getStaticPaths() {
  return getNavCategories().map((c) => ({ params: { category: c.id } }));
}

const { category } = Astro.params;
const cat = getCategory(category!);
if (!cat) return Astro.redirect('/');
---

<BaseLayout title={cat.title} description={cat.description} width="wide">
  <Breadcrumb items={[{ label: t('nav.home'), href: '/' }, { label: cat.title }]} />

  <section class="cat-hero">
    <h1 class="cat-hero-title">{cat.title}</h1>
    <p class="cat-hero-body">{cat.description}</p>
  </section>

  <section class="cat-grid">
    <CategoryCard category={cat} openByDefault={true} />
  </section>
</BaseLayout>

<style>
  .cat-hero {
    padding: var(--space-5) 0 var(--space-5);
    max-width: 720px;
  }
  .cat-hero-title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-3);
  }
  .cat-hero-body {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    line-height: 1.55;
  }
  .cat-grid { margin-top: var(--space-3); }
</style>
