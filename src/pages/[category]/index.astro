---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildClusterTree } from '../../lib/content';
import { t } from '../../lib/i18n';

export function getStaticPaths() {
  return buildClusterTree().map((c) => ({ params: { category: c.id } }));
}

const { category } = Astro.params;
const all = buildClusterTree();
const cluster = all.find((c) => c.id === category);
if (!cluster) return Astro.redirect('/');
---

<BaseLayout title={cluster.title} description={cluster.description} width="wide">
  <Breadcrumb items={[{ label: t('nav.home'), href: '/' }, { label: cluster.title }]} />

  <section class="cat-hero">
    <h1 class="cat-hero-title">{cluster.title}</h1>
    <p class="cat-hero-body">{cluster.description}</p>
  </section>

  <section class="cat-grid">
    <CategoryCard cluster={cluster} openByDefault={true} />
  </section>
</BaseLayout>

<style>
  .cat-hero {
    padding: var(--space-5) 0 var(--space-5);
    max-width: 720px;
  }
  .cat-hero-title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-3);
  }
  .cat-hero-body {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    line-height: 1.55;
  }
  .cat-grid {
    margin-top: var(--space-3);
  }
</style>
