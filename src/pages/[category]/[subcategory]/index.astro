---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SidebarNav from '../../../components/SidebarNav.astro';
import ArticleListItem from '../../../components/ArticleListItem.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Icon from '../../../components/Icon.astro';
import {
  getNavCategories,
  getSubtopic,
  loadLessonForArticle,
  categoryUrl,
} from '../../../lib/content';
import { t } from '../../../lib/i18n';

// Generate one page per (category, subtopic) pair across all 14 categories.
export function getStaticPaths() {
  const paths: { params: { category: string; subcategory: string } }[] = [];
  for (const c of getNavCategories()) {
    for (const s of c.subtopics) {
      paths.push({ params: { category: c.id, subcategory: s.id } });
    }
  }
  return paths;
}

const { category, subcategory } = Astro.params;
const ctx = getSubtopic(category!, subcategory!);
if (!ctx) return Astro.redirect('/');
const { category: cat, subtopic: sub } = ctx;
const categories = getNavCategories();

const articles = sub.articles;
const lessonsByArticleId = new Map<string, Awaited<ReturnType<typeof loadLessonForArticle>>>();
for (const a of articles) {
  if (a.published) lessonsByArticleId.set(a.id, loadLessonForArticle(a));
}

const pageTitle = `${sub.title} — ${cat.title}`;
---

<BaseLayout title={pageTitle} width="flush">
  <div class="page">
    <button class="sidebar-toggle" type="button" data-drawer-toggle aria-expanded="false" aria-controls="sidebar-drawer">
      <Icon name="menu" /> {t('list.allCategories')}
    </button>

    <div class="layout">
      <div id="sidebar-drawer" class="sidebar-wrap" data-drawer>
        <button class="sidebar-close" type="button" data-drawer-close aria-label="Close menu">
          <Icon name="close" />
        </button>
        <SidebarNav categories={categories} activeCategory={cat.id} activeSubtopic={sub.id} />
      </div>

      <main class="main-col">
        <Breadcrumb
          items={[
            { label: t('nav.home'), href: '/' },
            { label: cat.title, href: categoryUrl(cat.id) },
            { label: sub.title },
          ]}
        />

        <header class="head">
          <p class="eyebrow">{cat.title}</p>
          <h1 class="head-title">{sub.title}</h1>
        </header>

        {articles.length === 0 ? (
          <div class="empty">
            <p>{t('list.comingSoon')}</p>
          </div>
        ) : (
          <ul class="article-list" role="list">
            {articles.map((a) => (
              <li>
                <ArticleListItem article={a} lesson={lessonsByArticleId.get(a.id)} />
              </li>
            ))}
          </ul>
        )}
      </main>
    </div>
  </div>
</BaseLayout>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-drawer-toggle]');
  const drawer = document.querySelector<HTMLElement>('[data-drawer]');
  const close = document.querySelector<HTMLButtonElement>('[data-drawer-close]');

  function setOpen(open: boolean) {
    if (!drawer || !toggle) return;
    drawer.classList.toggle('open', open);
    toggle.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  }
  toggle?.addEventListener('click', () => setOpen(!drawer?.classList.contains('open')));
  close?.addEventListener('click', () => setOpen(false));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.classList.contains('open')) setOpen(false);
  });
</script>

<style>
  .page {
    max-width: var(--width-content);
    margin-inline: auto;
  }
  .sidebar-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin: var(--space-4);
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }
  @media (min-width: 960px) {
    .sidebar-toggle { display: none; }
  }

  .layout {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 60vh;
  }
  @media (min-width: 960px) {
    .layout {
      grid-template-columns: var(--width-sidebar) 1fr;
    }
  }

  .sidebar-wrap { display: none; }
  @media (min-width: 960px) {
    .sidebar-wrap {
      display: block;
      position: sticky;
      top: var(--topbar-h);
      height: calc(100vh - var(--topbar-h));
    }
    .sidebar-close { display: none; }
  }

  @media (max-width: 959.98px) {
    .sidebar-wrap {
      position: fixed;
      inset: 0;
      z-index: 80;
      background: var(--color-bg);
      transform: translateX(-100%);
      transition: transform 0.2s ease;
      overflow-y: auto;
    }
    .sidebar-wrap.open {
      transform: translateX(0);
      display: block;
    }
    .sidebar-close {
      position: absolute;
      top: var(--space-3);
      right: var(--space-3);
      z-index: 1;
      width: 38px;
      height: 38px;
      display: inline-grid;
      place-items: center;
      border-radius: 999px;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      color: var(--color-text);
    }
  }

  .main-col {
    padding: var(--space-4);
    min-width: 0;
  }
  @media (min-width: 768px) {
    .main-col { padding: var(--space-5) var(--space-6); }
  }
  .head { margin: var(--space-3) 0 var(--space-5); }
  .eyebrow {
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-2);
  }
  .head-title {
    font-size: var(--text-3xl);
    line-height: 1.2;
  }
  .article-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }
  .empty {
    padding: var(--space-7) var(--space-5);
    text-align: center;
    background: var(--color-surface);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
  }
</style>
