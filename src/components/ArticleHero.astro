---
// Article hero image (brief Item 5). Renders a responsive <img> that points at
// Cloudflare Images delivery URLs when configured, falling back to a bundled
// placeholder otherwise. Aspect-ratio box reserves space → zero CLS.
import {
  getArticleImage,
  getArticleImageSrcset,
  getArticleImageSizes,
  articleImagesEnabled,
} from '../lib/images';

interface Props {
  articleId: string;
  alt: string;
  /** Above-the-fold heroes load eagerly with high priority; others lazy. */
  eager?: boolean;
  aspectRatio?: '16:9' | '3:2' | '4:3' | '1:1';
}

const { articleId, alt, eager = true, aspectRatio = '16:9' } = Astro.props;

const enabled = articleImagesEnabled();
const src = getArticleImage(articleId, 'hero');
const srcset = enabled ? getArticleImageSrcset(articleId) : undefined;
const sizes = enabled ? getArticleImageSizes() : undefined;
---

<div class={`article-hero ${enabled ? '' : 'article-hero-placeholder'}`} data-aspect={aspectRatio}>
  <img
    src={src}
    srcset={srcset}
    sizes={sizes}
    alt={alt}
    width="1200"
    height="675"
    decoding="async"
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : undefined}
  />
</div>

<style>
  .article-hero {
    margin-top: var(--space-5);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface-alt);
  }
  .article-hero[data-aspect='16:9'] {
    aspect-ratio: 16 / 9;
  }
  .article-hero[data-aspect='3:2'] {
    aspect-ratio: 3 / 2;
  }
  .article-hero[data-aspect='4:3'] {
    aspect-ratio: 4 / 3;
  }
  .article-hero[data-aspect='1:1'] {
    aspect-ratio: 1 / 1;
  }
  .article-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Placeholder reads as a soft brand panel rather than a "broken image". */
  .article-hero-placeholder img {
    object-fit: contain;
    opacity: 0.9;
  }
</style>
