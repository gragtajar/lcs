---
// Compact card for the Visitors module on the homepage. Unlike CategoryCard,
// it doesn't expand into subtopic rows — it links to /visitors instead.

import Icon from './Icon.astro';
import { categoryIconName } from '../lib/icons';
import { t } from '../lib/i18n';
import { visitorsUrl } from '../lib/content';
import type { VisitorsView } from '../lib/content';

interface Props {
  visitors: VisitorsView;
}
const { visitors } = Astro.props;

const areasLabel = t('home.areaCount', { count: visitors.subtopicCount });
const lessonsLabel = t('home.lessonsPlanned', { count: visitors.lessonCount });
const meta = `${areasLabel} · ${lessonsLabel}`;
---

<a class="vcard" href={visitorsUrl()}>
  <span class="vcard-icon">
    <Icon name={categoryIconName(visitors.icon)} />
  </span>
  <span class="vcard-text">
    <span class="vcard-title-row">
      <span class="vcard-title">{visitors.title}</span>
      <span class="vcard-badge">{t('home.phaseBadge', { n: visitors.phase })}</span>
    </span>
    <span class="vcard-count">{meta}</span>
  </span>
  <Icon name="chevron_right" class="vcard-arrow" />
</a>

<style>
  .vcard {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    min-height: 64px;
    transition: border-color 0.12s ease;
  }
  .vcard:hover {
    border-color: color-mix(in srgb, var(--color-primary) 30%, var(--color-border));
    text-decoration: none;
  }
  .vcard-icon {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    flex-shrink: 0;
  }
  .vcard-icon :global(.icon) {
    width: 20px;
    height: 20px;
  }
  .vcard-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .vcard-title-row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .vcard-title {
    font-weight: 600;
    font-size: var(--text-lg);
    line-height: 1.3;
  }
  .vcard-badge {
    font-size: var(--text-xs);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    padding: 2px 8px;
    border-radius: 999px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .vcard-count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .vcard-arrow {
    color: var(--color-text-muted);
  }
</style>
