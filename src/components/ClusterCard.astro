---
// ClusterCard (homepage brief §2) — a featured cluster with 3 auto-selected article
// previews and a "Browse all" link. The card is an <article> with an internal <h3>
// for the cluster name; previews are full-target <a> links.
import Icon from './Icon.astro';
import { t, formatDate } from '../lib/i18n';
import { categoryIconName } from '../lib/icons';
import { categoryUrl } from '../lib/content';
import type { FeaturedCluster } from '../lib/homepage-data';

interface Props {
  featured: FeaturedCluster;
}

const { featured } = Astro.props;
const { category, articles } = featured;

const publishedCount = category.subtopics
  .flatMap((s) => s.articles)
  .filter((a) => a.published).length;
---

<article class="cluster-card">
  <header class="cluster-head">
    <span class="cluster-icon">
      <Icon name={categoryIconName(category.icon)} />
    </span>
    <div class="cluster-headtext">
      <h3 class="cluster-name">{category.title}</h3>
      <p class="cluster-desc">{category.description}</p>
    </div>
  </header>

  <div class="cluster-previews">
    {
      articles.map(({ lesson, url, englishOnly }) => {
        const excerpt = lesson.meta_description || lesson.tldr[0] || '';
        const formatLabel = t(`article.format.${lesson.format}`);
        const meta = `${t('list.minRead', { n: lesson.length_min })} · ${formatDate(lesson.last_updated)}`;
        return (
          <a class="preview" href={url}>
            <span class="preview-top">
              <span class="preview-format" aria-label={`${formatLabel} format`}>
                {formatLabel}
              </span>
              {englishOnly && (
                <span class="preview-en-badge" role="note">
                  {t('homepage.clusterCards.englishOnlyBadge')}
                </span>
              )}
            </span>
            <span class="preview-title">{lesson.title}</span>
            <span class="preview-excerpt">{excerpt}</span>
            <span class="preview-meta">{meta}</span>
          </a>
        );
      })
    }
  </div>

  <a class="cluster-browse" href={categoryUrl(category.id)}>
    {t('homepage.clusterCards.browseAll', { count: publishedCount, clusterName: category.title })}
  </a>
</article>

<style>
  .cluster-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    max-width: 960px;
    margin-inline: auto;
    width: 100%;
  }
  .cluster-head {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .cluster-icon {
    display: inline-grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--color-primary-soft);
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .cluster-icon :global(.icon) {
    width: 22px;
    height: 22px;
  }
  .cluster-headtext {
    min-width: 0;
  }
  .cluster-name {
    font-size: var(--text-xl);
    line-height: 1.25;
    margin: 0 0 2px;
  }
  .cluster-desc {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.5;
    margin: 0;
  }

  .cluster-previews {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
  @media (min-width: 1024px) {
    .cluster-previews {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .preview {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text);
    height: 100%;
    transition:
      border-color 0.12s ease,
      transform 0.12s ease;
  }
  .preview:hover {
    border-color: color-mix(in srgb, var(--color-primary) 35%, var(--color-border));
    text-decoration: none;
  }
  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .preview:hover {
      transform: translateY(-2px);
    }
  }
  .preview-top {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .preview-format {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    color: var(--color-primary);
  }
  .preview-en-badge {
    font-size: 11px;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 1px 8px;
  }
  .preview-title {
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.35;
  }
  .preview-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .preview-meta {
    margin-top: auto;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .cluster-browse {
    display: inline-block;
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
  }
</style>
