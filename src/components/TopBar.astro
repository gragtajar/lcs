---
import ThemeToggle from '../islands/ThemeToggle.tsx';
import SearchOverlay from '../islands/SearchOverlay.tsx';
import { t } from '../lib/i18n';
---

<header class="topbar" data-pagefind-ignore>
  <div class="topbar-inner">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true">civic</span>
      <span class="brand-name">{t('siteName')}</span>
    </a>

    <button
      class="search-trigger"
      type="button"
      data-search-trigger
      aria-label={t('topbar.openSearch')}
    >
      <svg viewBox="0 0 24 24" class="icon" aria-hidden="true">
        <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="1.6"
        ></circle>
        <path
          d="M16 16l4.5 4.5"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"></path>
      </svg>
      <span class="search-trigger-label">{t('topbar.searchPlaceholder')}</span>
      <kbd class="search-trigger-kbd">/</kbd>
    </button>

    <div class="topbar-actions">
      <ThemeToggle client:idle label={t('topbar.toggleTheme')} />
    </div>
  </div>

  <SearchOverlay
    client:idle
    strings={{
      open: t('topbar.openSearch'),
      close: t('topbar.closeSearch'),
      title: t('search.title'),
      placeholder: t('search.placeholder'),
      prompt: t('search.prompt'),
      noResults: t('search.noResults'),
      comingSoonChip: t('search.comingSoonChip'),
    }}
  />
</header>

<script>
  // Wire the (server-rendered) search trigger button to the (client-side) overlay.
  document.querySelectorAll('[data-search-trigger]').forEach((btn) => {
    btn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('lcs:open-search'));
    });
  });
</script>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: saturate(180%) blur(8px);
    -webkit-backdrop-filter: saturate(180%) blur(8px);
    border-bottom: 1px solid var(--color-border);
  }
  .topbar-inner {
    max-width: var(--width-content);
    margin-inline: auto;
    height: var(--topbar-h);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-inline: var(--space-4);
  }
  @media (min-width: 768px) {
    .topbar-inner {
      padding-inline: var(--space-6);
    }
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .brand:hover {
    color: var(--color-text);
    text-decoration: none;
  }
  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0;
  }
  .brand-name {
    font-size: 0.95rem;
  }
  .search-trigger {
    flex: 1;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-surface-alt);
    color: var(--color-text-muted);
    border-radius: 999px;
    padding: 0.4rem 0.8rem;
    font-size: var(--text-sm);
    border: 1px solid transparent;
    max-width: 420px;
    margin-inline: auto;
    transition: border-color 0.12s ease;
  }
  .search-trigger:hover {
    border-color: var(--color-border);
  }
  .search-trigger-label {
    flex: 1;
    text-align: left;
  }
  .search-trigger-kbd {
    color: var(--color-text-muted);
  }
  @media (max-width: 640px) {
    .search-trigger {
      flex: 0 0 auto;
      padding: 0.45rem;
      max-width: none;
    }
    .search-trigger-label,
    .search-trigger-kbd {
      display: none;
    }
  }
  .topbar-actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  :global(.theme-toggle) {
    width: 38px;
    height: 38px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    color: var(--color-text-secondary);
  }
  :global(.theme-toggle:hover) {
    color: var(--color-text);
    background: var(--color-surface-alt);
  }

  /* Search overlay (rendered by the island, styled here so SSR + hydration share it). */
  :global(.search-overlay) {
    position: fixed;
    inset: 0;
    z-index: 100;
  }
  :global(.search-backdrop) {
    /* Rendered as a button for keyboard accessibility; styled to look like a backdrop. */
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 45%);
    border: 0;
    padding: 0;
    cursor: default;
  }
  :global(.search-panel) {
    position: relative;
    margin: 6vh auto 0;
    max-width: 640px;
    background: var(--color-surface);
    color: var(--color-text);
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  @media (max-width: 640px) {
    :global(.search-panel) {
      margin: 0;
      border-radius: 0;
      height: 100vh;
      max-width: none;
    }
  }
  :global(.search-input-row) {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }
  :global(.search-input) {
    flex: 1;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    font-size: var(--text-base);
    outline: none;
  }
  :global(.search-close) {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 2px 6px;
  }
  :global(.search-results) {
    max-height: 60vh;
    overflow-y: auto;
    padding: var(--space-2) 0;
  }
  @media (max-width: 640px) {
    :global(.search-results) {
      max-height: calc(100vh - 70px);
    }
  }
  :global(.search-result) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-3) var(--space-4);
    color: var(--color-text);
    border-radius: 0;
  }
  :global(.search-result:hover),
  :global(.search-result.active) {
    background: var(--color-surface-alt);
    text-decoration: none;
  }
  :global(.search-result-title-row) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  :global(.search-result-title) {
    font-weight: 500;
  }
  :global(.search-result.soon .search-result-title) {
    color: var(--color-text-secondary);
  }
  :global(.search-result-chip) {
    font-size: var(--text-xs);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    padding: 1px 7px;
    border-radius: 999px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  :global(.search-result-breadcrumb) {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
  }
  :global(.search-empty) {
    color: var(--color-text-muted);
    padding: var(--space-5) var(--space-4);
    text-align: center;
  }
</style>
