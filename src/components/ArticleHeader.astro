---
import Icon from './Icon.astro';
import ArticleHero from './ArticleHero.astro';
import { t, formatDate } from '../lib/i18n';
import type { LessonFormat, Lesson } from '../lib/content';

// Header renders identically for published and coming-soon articles
// (per addendum §2.2). The difference is in the metadata row:
//   - published: reading time + last_updated date
//   - coming-soon: "Coming soon" badge + outlined format chip
//
// The image placeholder is always shown; for coming-soon it's slightly
// desaturated to soften the visual.

interface Props {
  title: string;
  format: LessonFormat;
  comingSoon: boolean;
  /** When published, pass the parsed lesson to fill length_min + last_updated. */
  lesson?: Lesson | null;
}

const { title, format, comingSoon, lesson } = Astro.props;
---

<header
  class={`ah ${comingSoon ? 'ah-soon' : ''}`}
  data-article-id={!comingSoon && lesson ? lesson.id : undefined}
>
  <h1 class="ah-title">{title}</h1>
  <div class="ah-meta">
    <span class={`ah-format ah-format-${format} ${comingSoon ? 'ah-format-outline' : ''}`}>
      {t(`article.format.${format}`)}
    </span>
    {
      comingSoon ? (
        <span class="ah-soon-badge">
          <Icon name="schedule" />
          {t('article.comingSoonBadge')}
        </span>
      ) : (
        <>
          <span class="ah-meta-item">
            <Icon name="schedule" /> {t('list.minRead', { n: lesson?.length_min ?? 3 })}
          </span>
          {lesson?.last_updated && (
            <span class="ah-meta-item">
              <Icon name="calendar" />{' '}
              {lesson.version
                ? t('list.lastUpdatedWithVersion', {
                    date: formatDate(lesson.last_updated),
                    version: lesson.version,
                  })
                : t('list.lastUpdated', { date: formatDate(lesson.last_updated) })}
            </span>
          )}
        </>
      )
    }
    {
      /*
      Future-favorites insertion point (spec §15.4): a bookmark button slots in here.
      Reserved as a placeholder so the layout doesn't shift when login + favorites land.
    */
    }
    <span class="ah-fav-slot" data-future-favorite hidden>
      <Icon name="bookmark" label={t('article.favoritePlaceholder')} />
    </span>
  </div>
  {
    comingSoon || !lesson ? (
      <div class="ah-image" aria-hidden="true">
        <div class={`ah-image-ph ${comingSoon ? 'ah-image-ph-soon' : ''}`} />
      </div>
    ) : (
      <ArticleHero articleId={lesson.id} alt={title} aspectRatio="16:9" />
    )
  }
</header>

<script>
  // Fire the `article-read` analytics event once the reader reaches the end of
  // a published article. A sentinel is appended to the article column and
  // observed; on first intersection we report the time spent on the page.
  // No-op when analytics is uninitialised (no key / Do-Not-Track).
  import { trackArticleRead } from '../lib/analytics';

  const header = document.querySelector<HTMLElement>('.ah[data-article-id]');
  const articleId = header?.dataset.articleId;
  const column = document.querySelector('.article');

  if (articleId && column) {
    const startedAt = performance.now();
    const sentinel = document.createElement('div');
    sentinel.setAttribute('aria-hidden', 'true');
    sentinel.style.height = '1px';
    column.append(sentinel);

    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        observer.disconnect();
        trackArticleRead({
          articleId,
          locale: document.documentElement.lang || 'en',
          timeOnPageMs: Math.round(performance.now() - startedAt),
        });
      }
    });
    observer.observe(sentinel);
  }
</script>

<style>
  .ah {
    padding: var(--space-4) 0 var(--space-5);
  }
  .ah-title {
    font-size: var(--text-3xl);
    line-height: 1.2;
    margin-bottom: var(--space-3);
  }
  @media (min-width: 768px) {
    .ah-title {
      font-size: 2.5rem;
    }
  }
  .ah-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .ah-meta-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }
  .ah-meta-item :global(.icon),
  .ah-soon-badge :global(.icon) {
    width: 15px;
    height: 15px;
  }
  .ah-soon-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    padding: 3px 9px;
    border-radius: 999px;
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .ah-format {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 9px;
    border-radius: 999px;
    font-weight: 500;
  }
  .ah-format-scenario {
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }
  .ah-format-rule {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }
  .ah-format-comparison {
    background: color-mix(in srgb, var(--color-text) 8%, transparent);
    color: var(--color-text-secondary);
  }
  .ah-format-outline {
    background: transparent !important;
    border: 1px solid currentColor;
    color: var(--color-text-muted) !important;
  }
  .ah-image {
    margin-top: var(--space-5);
    aspect-ratio: 16 / 9;
    background: var(--color-surface-alt);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .ah-image-ph {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-primary-soft) 70%, var(--color-surface-alt)),
      var(--color-surface-alt)
    );
  }
  .ah-image-ph-soon {
    filter: grayscale(0.7);
    opacity: 0.65;
  }
</style>
