---
import Icon from './Icon.astro';
import { categoryIconName } from '../lib/icons';
import { t } from '../lib/i18n';
import { subtopicUrl } from '../lib/content';
import type { NavCategory } from '../lib/content';

interface Props {
  category: NavCategory;
  /** Open the card by default on first render (use for the very first card). */
  openByDefault?: boolean;
  /** Optional small badge in the header (e.g., "Phase 4"). */
  badge?: string;
}

const { category, openByDefault = false, badge } = Astro.props;

const subsLabel = t('home.subcategoryCount', { count: category.subtopicCount });
const artsLabel = t('home.articleCount', { count: category.lessonCount });
const meta = t('home.categoryMeta', { subs: subsLabel, arts: artsLabel });
---

<details class="cat" data-cat-id={category.id} open={openByDefault}>
  <summary class="cat-header">
    <span class="cat-icon">
      <Icon name={categoryIconName(category.icon)} />
    </span>
    <span class="cat-text">
      <span class="cat-title-row">
        <span class="cat-title">{category.title}</span>
        {badge && <span class="cat-badge">{badge}</span>}
      </span>
      <span class="cat-count">{meta}</span>
    </span>
    <Icon name="expand_more" class="cat-chevron" />
  </summary>

  <ul class="sub-list" role="list">
    {category.subtopics.map((s) => (
      <li>
        <a class="sub-row" href={subtopicUrl(category.id, s.id)}>
          <span class="sub-title">{s.title}</span>
          <span class="sub-count">
            {t('home.articleCount', { count: s.articles.length })}
          </span>
          <Icon name="chevron_right" class="sub-arrow" />
        </a>
      </li>
    ))}
  </ul>
</details>

<style>
  .cat {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.12s ease;
  }
  .cat[open] {
    border-color: color-mix(in srgb, var(--color-primary) 25%, var(--color-border));
  }
  .cat-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    cursor: pointer;
    list-style: none;
    user-select: none;
    min-height: 64px;
  }
  .cat-header::-webkit-details-marker { display: none; }
  .cat-header:hover {
    background: var(--color-surface-alt);
  }
  .cat-icon {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-primary-soft);
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .cat-icon :global(.icon) { width: 20px; height: 20px; }
  .cat-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .cat-title-row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .cat-title {
    font-weight: 600;
    font-size: var(--text-lg);
    line-height: 1.3;
    color: var(--color-text);
  }
  .cat-badge {
    font-size: var(--text-xs);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    padding: 2px 8px;
    border-radius: 999px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .cat-count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .cat-chevron {
    color: var(--color-text-muted);
    transition: transform 0.2s ease;
  }
  .cat[open] .cat-chevron { transform: rotate(180deg); }

  .sub-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }
  .sub-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    color: var(--color-text);
    border-top: 1px solid transparent;
    min-height: 52px;
  }
  .sub-list li + li .sub-row {
    border-top-color: var(--color-border);
  }
  .sub-row:hover {
    background: var(--color-surface-alt);
    text-decoration: none;
  }
  .sub-title { flex: 1; font-size: var(--text-base); }
  .sub-count {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .sub-arrow {
    color: var(--color-text-muted);
    width: 18px;
    height: 18px;
  }
</style>
