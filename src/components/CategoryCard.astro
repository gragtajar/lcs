---
import Icon from './Icon.astro';
import { categoryIconName } from '../lib/icons';
import { t } from '../lib/i18n';
import { subtopicUrl } from '../lib/content';
import type { ClusterView } from '../lib/content';

interface Props {
  cluster: ClusterView;
  /** Server-render the first card open by default for fast above-the-fold reading. */
  openByDefault?: boolean;
}

const { cluster, openByDefault = false } = Astro.props;
---

<details class="cat" data-cat-id={cluster.id} open={openByDefault}>
  <summary class="cat-header">
    <span class="cat-icon">
      <Icon name={categoryIconName(cluster.icon)} />
    </span>
    <span class="cat-text">
      <span class="cat-title">{cluster.title}</span>
      <span class="cat-count">
        {t('home.subcategoryCount', { count: cluster.subtopics.length })}
      </span>
    </span>
    <Icon name="expand_more" class="cat-chevron" />
  </summary>

  <ul class="sub-list" role="list">
    {cluster.subtopics.map((s) =>
      s.empty ? (
        <li class="sub-row sub-row-empty">
          <span class="sub-title">{s.title}</span>
          <span class="sub-soon">{t('home.soon')}</span>
        </li>
      ) : (
        <li>
          <a class="sub-row" href={subtopicUrl(cluster.id, s.id)}>
            <span class="sub-title">{s.title}</span>
            <span class="sub-count">
              {t('home.articleCount', { count: s.publishedCount })}
            </span>
            <Icon name="chevron_right" class="sub-arrow" />
          </a>
        </li>
      )
    )}
  </ul>
</details>

<style>
  .cat {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.12s ease;
  }
  .cat[open] {
    border-color: color-mix(in srgb, var(--color-primary) 25%, var(--color-border));
  }
  .cat-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    cursor: pointer;
    list-style: none;
    user-select: none;
    min-height: 64px;
  }
  .cat-header::-webkit-details-marker {
    display: none;
  }
  .cat-header:hover {
    background: var(--color-surface-alt);
  }
  .cat-icon {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-primary-soft);
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .cat-icon :global(.icon) {
    width: 20px;
    height: 20px;
  }
  .cat-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cat-title {
    font-weight: 600;
    font-size: var(--text-lg);
    line-height: 1.3;
    color: var(--color-text);
  }
  .cat-count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .cat-chevron {
    color: var(--color-text-muted);
    transition: transform 0.2s ease;
  }
  .cat[open] .cat-chevron {
    transform: rotate(180deg);
  }

  .sub-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }
  .sub-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    color: var(--color-text);
    border-top: 1px solid transparent;
    min-height: 52px;
  }
  .sub-row + .sub-row,
  .sub-list li + li .sub-row {
    border-top-color: var(--color-border);
  }
  .sub-row:hover {
    background: var(--color-surface-alt);
    text-decoration: none;
  }
  .sub-title {
    flex: 1;
    font-size: var(--text-base);
  }
  .sub-count {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .sub-arrow {
    color: var(--color-text-muted);
    width: 18px;
    height: 18px;
  }
  .sub-row-empty {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    border-top: 1px solid var(--color-border);
  }
  .sub-row-empty:first-child {
    border-top: 0;
  }
  .sub-soon {
    font-size: var(--text-xs);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    padding: 2px 8px;
    border-radius: 999px;
    text-transform: lowercase;
  }
</style>
