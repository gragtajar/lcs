{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/traffic/index.html",
        "http://localhost/traffic/honking-discipline/index.html",
        "http://localhost/traffic/honking-discipline/the-case-against-honking/index.html",
        "http://localhost/queues-and-waiting/atms-and-banks/the-atm-line-the-one-meter-rule/index.html",
        "http://localhost/public-spaces/waste-disposal/where-the-wrapper-goes/index.html",
        "http://localhost/search/index.html",
        "http://localhost/visitors/index.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttling": { "cpuSlowdownMultiplier": 1 }
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "uses-text-compression": "error",
        "uses-responsive-images": "warn",
        "total-byte-weight": ["error", { "maxNumericValue": 200000 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 3000 }]
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
