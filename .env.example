# Build-time and client-side configuration for the website.
# Copy to .env (gitignored) for local dev, or set as repo secrets in CI.
#
# Vars prefixed PUBLIC_ are exposed to the browser via import.meta.env.
# Server-only vars (no PUBLIC_ prefix) stay in the build environment.

# --- Analytics ---
# Cloudflare Web Analytics token (Cloudflare dashboard → Web Analytics → site → Snippet).
# When set, the beacon is injected; when absent the site ships zero analytics JS.
PUBLIC_CF_ANALYTICS_TOKEN=

# --- Error monitoring (Sentry) ---
# DSN is public-ish (browser sees it) but kept server-side for build-time conditional inclusion.
SENTRY_DSN=

# Auth token for source-map upload during production builds.
# Generate at Sentry → Settings → Account → User Auth Tokens → scopes: project:releases, project:write.
SENTRY_AUTH_TOKEN=

# --- Deploy ---
# cPanel FTP credentials (existing deploy pipeline).
# Set as GitHub Actions repo secrets; do not commit values.
FTP_SERVER=
FTP_USERNAME=
FTP_PASSWORD=
