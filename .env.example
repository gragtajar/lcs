# Build-time and client-side configuration for the website.
# Copy to .env (gitignored) for local dev, or set as repo secrets in CI.
#
# Vars prefixed PUBLIC_ are exposed to the browser via import.meta.env.
# Server-only vars (no PUBLIC_ prefix) stay in the build environment.

# --- Analytics ---
# Cloudflare Web Analytics token (Cloudflare dashboard → Web Analytics → site → Snippet).
# When set, the beacon is injected; when absent the site ships zero analytics JS.
PUBLIC_CF_ANALYTICS_TOKEN=

# --- Error monitoring (Sentry) ---
# DSN is public-ish (browser sees it) but kept server-side for build-time conditional inclusion.
SENTRY_DSN=

# Auth token for source-map upload during production builds.
# Generate at Sentry → Settings → Account → User Auth Tokens → scopes: project:releases, project:write.
SENTRY_AUTH_TOKEN=

# --- Cloudflare account (Item 1) ---
# Fill from the Cloudflare dashboard after creating the account + zone.
CLOUDFLARE_ACCOUNT_ID=
# Scoped API token (NOT the global API key). Account:Read + Zone:Read.
CLOUDFLARE_API_TOKEN=
# Zone ID for learncivicsense.in.
CLOUDFLARE_ZONE_ID=

# --- Cloudflare Images (Item 5) ---
# Public delivery-URL account hash (Images dashboard).
CLOUDFLARE_IMAGES_ACCOUNT_HASH=
# Scoped token: Images:Edit (only needed for uploads/management, not delivery).
CLOUDFLARE_IMAGES_API_TOKEN=
# Same hash as above, exposed to the browser bundle for building <img> URLs.
PUBLIC_CLOUDFLARE_IMAGES_ACCOUNT_HASH=

# --- Amplitude product analytics (Item 2) ---
# Browser SDK API key. When absent, analytics is simply not initialised.
PUBLIC_AMPLITUDE_API_KEY=
# Optional; defaults to the official endpoint.
PUBLIC_AMPLITUDE_SERVER_URL=https://api2.amplitude.com/2/httpapi

# --- Deploy ---
# cPanel FTP credentials (existing deploy pipeline).
# Set as GitHub Actions repo secrets; do not commit values.
FTP_SERVER=
FTP_USERNAME=
FTP_PASSWORD=
